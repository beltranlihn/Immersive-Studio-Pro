# dependencies & build output (regenerable via npm install / npm run dist)
node_modules/
dist/
native/*/build/
native/*/node_modules/

# logs & scratch artifacts
*.log
scratchpad/out/
scratchpad/*.log
scratchpad/*.output
scratchpad/*.png

# OS cruft
Thumbs.db
.DS_Store

# Claude Code: versionar el tooling reusable (skills/agents/commands/settings),
# dejar fuera el estado/config local y lo sensible (settings.local.json, caches, etc.)
.claude/*
!.claude/skills/
!.claude/agents/
!.claude/commands/
!.claude/settings.json
.claude/settings.local.json
.claude/*.local.json
